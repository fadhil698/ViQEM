"""
example_sync_config.json - Contoh konfigurasi untuk sync.py
Copy dan edit sesuai dengan setup Anda
"""
{
    "ssh_config": {
        "hostname": "your-remote-server.com",
        "port": 22,
        "username": "your_username",
        "password": null,
        "key_filename": "~/.ssh/id_rsa",
        "timeout": 30
    },
    "local_project_dir": "/path/to/local/qem_project",
    "remote_project_dir": "/home/username/qem_project",
    "output_dirs": [
        "workflow_output",
        "qem_output", 
        "pipeline_output",
        "models"
    ],
    "exclude_patterns": [
        "*.pyc",
        "__pycache__",
        ".git",
        ".venv",
        "*.egg-info",
        ".pytest_cache",
        ".ipynb_checkpoints",
        "*.log",
        ".DS_Store"
    ]
}
